{
  "name": "vso-testingbot-plugin",
  "version": "0.3.5",
  "description": "TestingBot integration with Azure DevOps",
  "scripts": {
    "clean": "rimraf dist Packages \"tb-*/index.js\" \"tb-*/index.js.map\" \"tb-*/tests/**/*.js\" \"tb-*/tests/**/*.js.map\"",
    "precompile": "node scripts/ensure-task-src-deps.js",
    "compile": "tsc -p tb-main/tsconfig.json && tsc -p tb-stop-tunnel/tsconfig.json",
    "typecheck": "tsc -p tb-build-info/tsconfig.json",
    "lint": "eslint .",
    "build": "webpack --mode production",
    "deps": "node scripts/install-task-deps.js",
    "stamp": "node scripts/stamp-version.js",
    "test": "npm run compile && mocha \"tb-*/tests/**/*.js\"",
    "create": "tfx extension create --root dist --manifest-globs vss-extension.json --output-path Packages",
    "package": "npm run clean && npm run compile && npm run typecheck && npm run build && npm run deps && npm run stamp && npm run create"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/testingbot/vso-testingbot-plugin"
  },
  "author": "TestingBot <info@testingbot.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-typescript": "^8.0.1",
    "@eslint/js": "^9.18.0",
    "@types/blueimp-md5": "^2.18.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.17.0",
    "azure-devops-extension-api": "^5.275.0",
    "azure-devops-extension-sdk": "^4.2.0",
    "babel-loader": "^10.1.1",
    "blueimp-md5": "^2.19.0",
    "buffer": "^6.0.3",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "mocha": "^11.7.6",
    "rimraf": "^6.1.3",
    "tfx-cli": "^0.23.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0",
    "vss-web-extension-sdk": "^1.106.0",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1"
  }
}
